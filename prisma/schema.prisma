generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            Int       @default(autoincrement()) @id
  username      String    @unique
  password      String
}

model Todo {
  id             Int         @id
  title          String     
  description    String
  is_done        Boolean
  user_id        Int
}