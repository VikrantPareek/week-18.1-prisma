generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id       Int    @id @default(autoincrement())
  username String @unique
  password String
  todos  Todo[]
  timing     String @default("j")
}

model Todo {
  id Int @id @default(autoincrement())
  userId Int
  user User @relation(fields: [userId], references: [id])
}
